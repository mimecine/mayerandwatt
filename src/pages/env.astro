---
import Layout from "../layouts/Layout.astro";
const { env } = Astro.locals.runtime;
const SERVICE_MAYERANDWATT = env.SERVICE_MAYERANDWATT || 'Not Defined';

// let counter = parseInt(await SERVICE_MAYERANDWATT.get("counter")) || 0;
// console.log("Initial API Key:", currentTokenExpiry);
// console.log("Initial API Key Expiry:", parseInt(apiExpiry));
// console.log("Date Test:", Date.now() > parseInt(apiExpiry), Date.now(), parseInt(apiExpiry));
// console.log(parseInt(apiExpiry) - Date.now() != 0 ? "Not Expired" : "Expired");

// if( (Date.now() > parseInt(apiExpiry)) ) {
//     // Generate new API key
//     console.log("Generating new API Key");
//     apiKey = crypto.randomUUID();
//     apiExpiry = (Date.now() +  20 * 1000).toString(); // 1 minute expiry
//     await SERVICE_MAYERANDWATT.put("currentAuthKey", apiKey);
//     await SERVICE_MAYERANDWATT.put("currentAuthKeyExpiry", apiExpiry);
// }   

const getAccessToken = async () => {

    let currentAccessToken = await SERVICE_MAYERANDWATT.get("currentAccessToken");
    let currentTokenExpiry = await SERVICE_MAYERANDWATT.get("currentTokenExpiry");
    if(currentAccessToken && currentTokenExpiry && (Date.now() < parseInt(currentTokenExpiry))) {
        console.log("Using cached API Key:", currentAccessToken);
        return {accessToken: currentAccessToken, expiresIn: parseInt(currentTokenExpiry) - Date.now()};
    }
    try {
    let res = await fetch("https://accounts.zoho.com/oauth/v2/token", {
        method: "POST",
        headers: {
            "Content-Type": "application/x-www-form-urlencoded"
        },
        body: new URLSearchParams({
            "client_id": env.CLIENT_ID,
            "client_secret": env.CLIENT_SECRET,
            "grant_type": "client_credentials",
            "scope": env.ACCESS_SCOPE,
            "soid": env.SOID
        })
    });
    let json = await res.json();
    console.log(JSON.stringify(json));
    let {access_token, expires_in} = json;
    let expiryTimestamp = Date.now() + (expires_in * 1000);
    await SERVICE_MAYERANDWATT.put("currentAccessToken", access_token);
    await SERVICE_MAYERANDWATT.put("currentTokenExpiry", expiryTimestamp.toString());

    console.log("Fetched new API Key from Zoho:", access_token);
    return {accessToken:access_token, expiresIn:expires_in};
    } catch(err) {
        console.error("Error fetching access token:", err);
        return {accessToken:null, expiresIn:0}; 
    }  
}; 

const {accessToken, expiresIn} = await getAccessToken();
console.log("Access Token:", accessToken);
console.log("Expires In (ms):", expiresIn);

let resEmails = await fetch("https://www.zohoapis.com/crm/v8/Contacts?fields=Email,First_Name&per_page=100", {
    method: "GET",
    headers: {
        "Authorization": `Zoho-oauthtoken ${accessToken}`
    },
});

let resProducts = await fetch("https://www.zohoapis.com/crm/v8/Products?fields=Product_Name&per_page=100", {
    method: "GET",
    headers: {
        "Authorization": `Zoho-oauthtoken ${accessToken}`
    },
});
export const prerender = false;
---
<Layout>
    <h1>Environment Variable Test</h1>
    <p>Access Token: {accessToken}</p>
    <p>Expires In (ms): {expiresIn}</p>
    {resEmails.ok ? (
        <div>
            <h2>Contacts Emails:</h2>
            <ul>
            {
                (await resEmails.json()).data.map(contact => (
                    <li>{contact.Email}</li>
                    <li>{contact.First_Name}</li>
                ))
            }
            </ul>
        </div>
    ) : (
        <p>Error fetching contacts: {resEmails.status} {resEmails.statusText}</p>
    ) }
    {resProducts.ok ? (
        <div>
            <h2>Products:</h2>
            <ul>
            {
                (await resProducts.json()).data.map(product => (
                    <li>{product.Product_Name}</li>
                ))
            }
            </ul>
        </div>
    ) : (
        <p>Error fetching products: {resProducts.status} {resProducts.statusText}</p>
    ) }
</Layout>

